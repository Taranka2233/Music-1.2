{
  "name": "n54-audio-deck",
  "version": "1.0.0",
  "private": true,
  "description": "Матовая киберпанк-дека: локальный аудиоплеер на одном HTML-файле",
  "scripts": {
    "add:android": "cap add android && node scripts/patch-android.mjs",
    "sync": "node scripts/patch-android.mjs && cap sync android",
    "apk": "cd android && ./gradlew assembleDebug",
    "serve": "npx --yes serve www -l 5173",
    "assets": "capacitor-assets generate --android"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@jofr/capacitor-media-session": "^4.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@capacitor/assets": "^3.0.5"
  }
}